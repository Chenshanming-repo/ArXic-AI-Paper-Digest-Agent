# Required: API key for an OpenAI-compatible chat completions endpoint.
API_KEY=sk-...

# Optional: third-party OpenAI-compatible endpoint.
# Leave empty to use OpenAI's default endpoint.
# BASE_URL=https://api.example.com/v1

# Optional overrides - uncomment and edit if you want to change defaults.
# ARXIV_CATEGORIES=cs.AI,cs.LG,stat.ML,q-bio.QM,q-bio.GN
# ARXIV_TOPIC_KEYWORDS=artificial intelligence,machine learning,deep learning,neural,transformer,large language model,llm,foundation model,diffusion model,reinforcement learning,representation learning,bioinformatics,computational biology,genomics,proteomics,single-cell,protein,dna,rna
# MAX_PAPERS=10
# ARXIV_PAGE_SIZE=50
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=300
# ROLLUP_MAX_TOKENS=1200
# ENABLE_WEEKLY_SUMMARY=true
# ENABLE_MONTHLY_SUMMARY=true
