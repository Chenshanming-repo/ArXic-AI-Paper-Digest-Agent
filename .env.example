# Required: API key for an OpenAI-compatible chat completions endpoint.
API_KEY=sk-...

# Optional: third-party OpenAI-compatible endpoint.
# Leave empty to use OpenAI's default endpoint.
# BASE_URL=https://api.example.com/v1

# Optional overrides - uncomment and edit if you want to change defaults.
# ARXIV_CATEGORIES=cs.AI,cs.LG,stat.ML,q-bio.QM,q-bio.GN
# ARXIV_TOPIC_KEYWORDS=artificial intelligence,machine learning,deep learning,neural,transformer,large language model,llm,foundation model,diffusion model,reinforcement learning,representation learning,bioinformatics,computational biology,genomics,proteomics,single-cell,protein,dna,rna
# MAX_PAPERS=0
# ARXIV_PAGE_SIZE=200
# ARXIV_USER_AGENT=LongReadPaperBot/0.1 (mailto:you@example.com)
# ARXIV_RATE_LIMIT_SECONDS=3.5
# ARXIV_RATE_LIMIT_JITTER_SECONDS=1.5
# ARXIV_MAX_RETRIES=5
# OPENAI_MODEL=auto
# OPENAI_MAX_TOKENS=300
# ROLLUP_MAX_TOKENS=1200
# ENABLE_WEEKLY_SUMMARY=true
# ENABLE_MONTHLY_SUMMARY=true

# Optional email delivery. EMAIL_RECIPIENTS enables sending.
# EMAIL_RECIPIENTS=alice@example.com,bob@example.com
# EMAIL_FROM=ArXiv Digest <digest@example.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=digest@example.com
# SMTP_PASSWORD=app-password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# EMAIL_SEND_DAILY=true
# EMAIL_SEND_WEEKLY=true
# EMAIL_SEND_MONTHLY=true

# Optional per-recipient category routing. JSON list of
# {email, categories} objects. When set and non-empty, the daily
# digest sends one filtered email per subscription instead of a
# single email to EMAIL_RECIPIENTS. Categories must appear in
# ARXIV_CATEGORIES; unknown categories are warned and dropped.
# RECIPIENTS_BY_CATEGORY=[{"email":"alice@x.com","categories":["cs.AI","cs.LG"]},{"email":"bob@y.com","categories":["stat.ML"]}]
